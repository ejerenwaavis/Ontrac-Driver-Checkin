MONGODBURI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=driverCheckin
FRONTEND_URL=https://drivercheckin.yourdomain.com
PORT=4000
JWT_SECRET=<run: openssl rand -hex 32>
JWT_REFRESH_SECRET=<run: openssl rand -hex 32>
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=<strong password — min 12 chars>
NODE_ENV=production
